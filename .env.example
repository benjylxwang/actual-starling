# actual-starling configuration. Copy to .env and fill in. NEVER commit .env.
# -----------------------------------------------------------------------------

# --- Actual Budget server ----------------------------------------------------
# URL of your self-hosted Actual server.
ACTUAL_SERVER_URL=https://actual.example.com
# Server password (the one you log in to the Actual web UI with).
ACTUAL_PASSWORD=your-actual-server-password
# Budget Sync ID — a UUID. Find it in Actual: Settings -> Advanced -> Sync ID.
# This is NOT the human-readable budget name.
ACTUAL_SYNC_ID=00000000-0000-0000-0000-000000000000
# End-to-end encryption password. Only set this if your budget is E2E encrypted.
# Leave blank/unset otherwise.
ACTUAL_E2E_PASSWORD=
# Local cache directory for the downloaded budget. Defaults to ./.actual-cache
ACTUAL_DATA_DIR=./.actual-cache

# --- Importer behaviour ------------------------------------------------------
# Rolling window of days to pull each run. Re-pulling overlapping windows is
# safe — dedupe is on Starling's feedItemUid.
LOOKBACK_DAYS=30
# Optional global start-date floor (YYYY-MM-DD), applied to every source that
# does not set its own SOURCE_n_START_DATE. Drops feed items dated before this.
# IMPORT_START_DATE=2026-06-26
# Optional: point at the Starling sandbox. Defaults to production.
# STARLING_BASE_URL=https://api-sandbox.starlingbank.com

# --- Sources -----------------------------------------------------------------
# One source = one real Starling account -> one Actual account.
# Personal, Joint, Easy Saver, Fixed Saver, Cash ISA are SEPARATE accounts, so
# give each its own SOURCE_n block. Number them 1, 2, 3, ... with no gaps.
#
# A "Spending Space" is a pot INSIDE an account, not a separate account — do NOT
# give it its own source. Its movements show in the parent feed as internal
# transfers and are dropped by the default skipSources filter.

# Source 1 — e.g. Personal current account
SOURCE_1_NAME=Personal
# Starling personal access token (read-only scopes — see below).
SOURCE_1_STARLING_TOKEN=your-starling-personal-access-token
# The Actual account id to import into. Run `npm run list-accounts` to get ids.
SOURCE_1_ACTUAL_ACCOUNT_ID=actual-account-uuid-here
# Optional: pin which Starling account on this token to use. If a token returns
# several accounts (e.g. current account + Easy Saver) and you omit this, the
# first one is used. Run `npm run discover` to see the accountUids.
# SOURCE_1_ACCOUNT_UID=starling-account-uid
# Optional: comma-separated Starling `source` values to drop.
# Defaults to INTERNAL_TRANSFER (Space/pot movements). Set to empty to keep all.
# SOURCE_1_SKIP_SOURCES=INTERNAL_TRANSFER
# Optional hard floor (YYYY-MM-DD). Feed items dated BEFORE this are never
# imported. Use when taking an account over from another importer (e.g.
# GoCardless bank sync): set it to the day AFTER the last transaction that
# importer added, so the overlap isn't re-imported as duplicates. See the
# "Migrating from GoCardless" section of the README.
# SOURCE_1_START_DATE=2026-06-26

# Source 2 — e.g. Easy Saver (often on the same token as Personal)
# SOURCE_2_NAME=Easy Saver
# SOURCE_2_STARLING_TOKEN=your-starling-personal-access-token
# SOURCE_2_ACTUAL_ACCOUNT_ID=another-actual-account-uuid
# SOURCE_2_ACCOUNT_UID=easy-saver-account-uid

# -----------------------------------------------------------------------------
# Required Starling READ-ONLY scopes when creating the personal access token:
#   account:read        list accounts
#   balance:read        read balances (used by `discover`)
#   transaction:read    read the transaction feed
#   savings-goal:read   list savings goals (used by `discover`)
#   space:read          list spaces (used by `discover`)
# `import` strictly needs only account:read + transaction:read.
